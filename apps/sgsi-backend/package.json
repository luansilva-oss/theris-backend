{
  "name": "sgsi-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build:prod": "npx prisma generate && npx tsc -p tsconfig.json && npx prisma migrate deploy",
    "start": "node dist/index.js",
    "migrate": "npx prisma migrate deploy",
    "migrate:dev": "npx prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "express": "^4.18.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
