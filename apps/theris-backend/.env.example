# === Auth refactor (26/abr/2026) ===
# Gerar 64 chars random com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_PEPPER=__GERAR__
CSRF_SECRET=__GERAR__
IP_PEPPER=__GERAR__
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=12
# Set true APENAS no deploy do refactor; reverte para false no deploy seguinte
FORCE_SESSION_INVALIDATION=false
APP_BASE_URL=https://theris.grupo-3c.com

# === Frontend (Vite) ===
# Modo de autenticacao do cliente: 'legacy' (header x-user-id) ou 'cookie' (cookie httpOnly + CSRF).
# Em producao usar 'cookie'. Durante dev local, alternar conforme bloco do refactor (Bloco 6=legacy, Bloco 7+=cookie).
VITE_AUTH_MODE=legacy
VITE_API_URL=

GOOGLE_WORKSPACE_HOSTED_DOMAIN=grupo-3c.com

# === Database (Neon) ===
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...

# === Google OAuth ===
GOOGLE_ID_CLIENT=...
GOOGLE_CLIENT_SECRET=...

# === Slack ===
SLACK_BOT_TOKEN=...
SLACK_SIGNING_SECRET=...

# === JumpCloud ===
JUMPCLOUD_CLIENT_ID=sa_...
JUMPCLOUD_CLIENT_SECRET=...
JUMPCLOUD_ORG_ID=...
JUMPCLOUD_API_KEY=...

# === Outros ===
CLICKUP_API_TOKEN=...
SGSI_SERVICE_TOKEN=...
NODE_ENV=production
