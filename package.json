{
  "name": "theris-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:theris": "npm run dev --workspace=apps/theris-backend",
    "dev:sgsi": "npm run dev --workspace=apps/sgsi-backend",
    "build:theris": "npm run build:prod --workspace=apps/theris-backend",
    "build:sgsi": "npm run build:prod --workspace=apps/sgsi-backend",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
